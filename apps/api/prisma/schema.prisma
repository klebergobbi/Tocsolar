generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id               String   @id @default(uuid())
  nome             String
  whatsapp         String
  email            String?
  cidade           String?
  tipo             String // 'residencial' | 'empresarial' | 'rural'
  valorConta       Float?
  economiaEstimada Float?
  systemKwp        Float?
  origem           String? // utm_source
  campanha         String? // utm_campaign
  mensagem         String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
}
