# Template das variáveis de produção da stack TOCSOLAR (droplet + Docker Compose).
# Copie para infrastructure/.env.prod e preencha. O .env.prod real é gitignorado (tem segredos).
#   cp infrastructure/.env.prod.example infrastructure/.env.prod
# Deploy:  bash infrastructure/deploy.sh   (ou docker compose -f infrastructure/docker-compose.prod.yml --env-file infrastructure/.env.prod up -d --build)

# === Postgres ===
# Senha do banco. Gere uma forte (ex.: openssl rand -hex 16).
POSTGRES_PASSWORD=

# === API (runtime) ===
# host "postgres"/"redis" = nomes dos serviços na rede do Compose (não localhost).
# Use a MESMA senha de POSTGRES_PASSWORD na DATABASE_URL.
DATABASE_URL=postgresql://tocsolar:CHANGE_ME@postgres:5432/tocsolar?schema=public
REDIS_HOST=redis
REDIS_PORT=6379
PORT=3001
NODE_ENV=production
# Origem permitida no CORS — o IP/domínio público do site (sem barra final).
CORS_ORIGIN=http://SEU_IP_OU_DOMINIO
LEAD_NOTIFY_WHATSAPP=5585991618044

# === Web (build args, embutidos no bundle em build time) ===
# Apontam para o domínio/IP público. NEXT_PUBLIC_API_URL inclui o sufixo /api (prefixo global do Nest + rota do Caddy).
NEXT_PUBLIC_API_URL=http://SEU_IP_OU_DOMINIO/api
NEXT_PUBLIC_SITE_URL=http://SEU_IP_OU_DOMINIO
NEXT_PUBLIC_GTM_ID=

# === Notificações (opcionais) — <<CONFIRMAR>>; vazios = desativadas ===
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
SMTP_URL=
SMTP_FROM=
LEAD_NOTIFY_EMAIL=
